# OmnissiahCore — .gitignore
# Do NOT commit the FAISS index or metadata — they are huge binary files.
# Transfer them manually from Lenovo to Dell via USB or network share.

# ── Large binary index files (transfer manually) ──────────────────────────
Db/faiss.index
Db/metadata.json
Db/
*.index
# ── Processed/tracking files (machine-local) ─────────────────────────────
Db/processed_files.json

# ── Raw data directories ──────────────────────────────────────────────────
Data/raw_pdfs/
Data/failed_pdfs/

# ── Python cache ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────
*.log

Db/faiss.index
Db/metadata.json
Db/processed_files.json
*.venv
.venv/
__pycache__/
*.pyc
