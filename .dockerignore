# OmnissiahCore — .dockerignore
# Keeps the Docker build context lean (~code only).
# Large files come from Hugging Face at runtime via pull_index.py.

# Virtual environment — rebuilt inside Docker from requirements.docker.txt
.venv/
venv/
env/

# Large data files — pulled from HF at runtime
Db/
bge_m3_onnx/

# Raw source books — only needed for building the index, not querying
Books/
PDFs/
*.pdf
*.epub
*.azw3
*.mobi
*.djvu

# Git
.git/
.gitignore
.gitattributes

# Dev/test
Tests/
Scripts/build_db.py
Scripts/verify_db.py
Scripts/query_test.py
*.pyc
__pycache__/
.pytest_cache/

# IDE
.idea/
*.iml

# Logs and temp
*.log
*.zip
*.tar
*.txt
!requirements.docker.txt

# OS
Thumbs.db
.DS_Store
