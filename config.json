      "retrieval": {
        "use_faiss": true,
        "use_bm25": true,
        "use_reranker": true,
        "rerank_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
        "candidate_pool": 30,
        "top_k": 8,
        "stitching_window": 2,
        "rrf_k": 60
      },
      "ollama": {
        "url": "http://localhost:11434/api/chat",
        "model": "qwen3:14b",
        "num_ctx": 8192,
        "temperature": 0.4,
        "top_p": 0.9,
        "max_tokens": 2048,
        "stream": true,
        "timeout": 180
      },
      "chunking": {
        "target_tokens": 350,
        "overlap_sentences": 2
      },
      "paths": {
        "pdf_dir": "Data/raw_pdfs",
        "failed_dir": "Data/failed_pdfs",
        "db_dir": "Db"
      }
    },

    "dell_query": {
      "_comment": "Low-memory query-only machine. 8GB RAM. Inference only.",
